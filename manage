<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Your wedding — Kymella</title>
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ccircle cx='16' cy='16' r='15' fill='%231C2B23'/%3E%3Ctext x='16' y='21' text-anchor='middle' font-family='Georgia' font-size='14' fill='%23C6A15B'%3E%26%3C/text%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,ital@9..144,300..700,0..1&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500&display=swap" rel="stylesheet">
<style>
:root{--ink:#0E1F1C;--ink-2:#152D28;--ink-3:#26433C;--ivory:#F5EFE3;--ivory-2:#EDE5D4;--paper:#fff;--sage:#6E8880;--sage-soft:#BFCFC9;--gold:#B8874A;--gold-soft:#E8C9A0;--gold-deep:#8E6836;--line:rgba(14,31,28,.12);--disp:'Fraunces',Georgia,serif;--body:'Inter',system-ui,sans-serif;--mono:'IBM Plex Mono',monospace}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:var(--body);background:var(--ivory);color:var(--ink);font-size:15px;line-height:1.6;-webkit-font-smoothing:antialiased}
button{font-family:var(--body);cursor:pointer;border:none;background:none;color:inherit}
input,textarea{font-family:var(--body);font-size:15px}
:focus-visible{outline:2px solid var(--gold);outline-offset:3px}
.label{font-size:10.5px;letter-spacing:.3em;text-transform:uppercase;color:var(--gold-deep);font-weight:600}
.label.muted{color:var(--sage)}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:12px 22px;font-weight:600;font-size:12px;letter-spacing:.08em;text-transform:uppercase;transition:all .25s;border-radius:2px}
.btn-solid{background:var(--ink);color:var(--ivory)}.btn-solid:hover{background:var(--ink-2)}
.btn-quiet{border:1px solid var(--line);color:var(--ink)}.btn-quiet:hover{border-color:var(--gold)}
.btn.xs{padding:8px 14px;font-size:11px}
.top{background:var(--ink);color:var(--ivory);padding:40px 22px 34px;text-align:center}
.top .names{font-family:var(--disp);font-size:clamp(26px,5vw,36px);font-weight:500;margin-top:10px}
.top .sub{color:var(--sage-soft);font-size:13px;margin-top:6px}
.wrap{max-width:760px;margin:0 auto;padding:26px 18px 90px}
.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:12px;margin-bottom:20px}
.stat{background:var(--paper);border:1px solid var(--line);padding:18px;text-align:center}
.stat .n{font-family:var(--disp);font-size:34px;font-weight:500;line-height:1;font-variant-numeric:tabular-nums}
.stat .l{font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--sage);font-weight:700;margin-top:8px}
.card{background:var(--paper);border:1px solid var(--line);padding:24px;margin-bottom:16px}
.card h3{font-family:var(--disp);font-size:22px;font-weight:600;margin-bottom:4px}
.card .ph{display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:14px}
.card .ph p{font-size:13px;color:var(--ink-3)}
.guest{display:grid;grid-template-columns:1fr auto auto;gap:8px 14px;padding:14px 2px;border-bottom:1px solid var(--line);align-items:center}
.guest:last-child{border:none}
.guest .nm{font-weight:700;font-size:14px}
.guest .em{font-size:12px;color:var(--ink-3)}
.guest .meal{font-size:11.5px;color:var(--sage);margin-top:2px}
.pill{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:5px 11px;border:1px solid}
.pill.yes{color:#3E6B4A;border-color:#BDD4C2;background:#F0F6F1}
.pill.no{color:#A4523F;border-color:#E4C2B8;background:#FAF0ED}
.pill.wait{color:#8F6F32;border-color:var(--gold-soft);background:#FBF7EC}
.note-row{padding:12px 2px;border-bottom:1px solid var(--line);font-size:14px}
.note-row:last-child{border:none}
.note-row b{font-weight:700}
.note-row span{color:var(--ink-3)}
.addg{display:grid;grid-template-columns:1fr 1fr auto;gap:10px;margin-top:14px}
.addg input{border:1px solid var(--line);padding:12px;outline:none}
.addg input:focus{border-color:var(--gold)}
@media(max-width:560px){.addg{grid-template-columns:1fr}.guest{grid-template-columns:1fr auto}.guest .actions{grid-column:1/-1}}
.state{min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--ink);color:var(--ivory);text-align:center;padding:24px}
.state h1{font-family:var(--disp);font-weight:500;font-size:26px;margin-bottom:10px}
.state p{color:var(--sage-soft);font-size:14px;max-width:380px}
.notice{position:fixed;bottom:0;left:0;right:0;background:var(--ink);color:var(--ivory);font-size:13px;text-align:center;padding:13px 20px;transform:translateY(100%);transition:transform .4s cubic-bezier(.22,1,.36,1);z-index:200}
.notice.on{transform:none}
.hidden{display:none!important}
.empty{text-align:center;padding:26px;color:var(--sage);font-size:13.5px}
</style>
</head>
<body>
<div class="state" id="stErr"><div><h1>This link isn't complete</h1><p>Open the private dashboard link you saved when you created your wedding — it contains your key.</p></div></div>
<div class="hidden" id="app">
  <div class="top">
    <div class="label" style="color:var(--gold-soft)">Your wedding</div>
    <div class="names" id="hNames"></div>
    <div class="sub" id="hSub"></div>
  </div>
  <div class="wrap">
    <div class="stats" id="stats"></div>
    <div class="card hidden" id="allergyCard" style="border-color:var(--gold-soft);background:#FBF7EC">
      <div class="ph"><div><h3>For the kitchen</h3><p>Every allergy and dietary need, grouped and counted, ready to hand to your caterer.</p></div></div>
      <div id="allergyList"></div>
    </div>
    <div class="card hidden" id="eventCard">
      <div class="ph"><div><h3>Who's coming to what</h3><p>Attendance by event, for multi-day celebrations.</p></div></div>
      <div id="eventList"></div>
    </div>
    <div class="card"><div class="ph"><div><h3>Guests & invitations</h3><p>Copy a link, send it over WhatsApp yourself — invitations should come from you.</p></div>
      <div style="display:flex;gap:8px"><button class="btn btn-quiet xs" onclick="exportCsv()">Export CSV</button><button class="btn btn-quiet xs" onclick="load()">Refresh</button></div></div>
      <div id="guestList"></div>
      <div class="addg">
        <input id="ng-name" placeholder="Guest name">
        <input id="ng-email" placeholder="Email (optional)">
        <button class="btn btn-solid" onclick="addGuest()">Add guest</button>
      </div>
    </div>
    <div class="card hidden" id="notesCard"><div class="ph"><div><h3>Questions & notes from guests</h3><p>Collected automatically from their replies.</p></div></div><div id="notesList"></div></div>
    <div class="card hidden" id="songsCard"><div class="ph"><div><h3>Song requests</h3><p>What your guests want to hear.</p></div></div><div id="songsList"></div></div>
    <div class="card"><div class="ph"><div><h3>Meal counts</h3><p>For your caterer.</p></div></div><div id="mealList"></div></div>
  </div>
</div>
<div class="notice" id="notice"></div>
<script>
const $=id=>document.getElementById(id);
const esc=s=>String(s??"").replace(/[&<>"']/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;"}[c]));
function notice(m){const n=$("notice");n.textContent=m;n.classList.add("on");clearTimeout(n._t);n._t=setTimeout(()=>n.classList.remove("on"),2600)}
const P=new URLSearchParams(location.hash.slice(1));
const WID=P.get("w"), KEY=P.get("k");
let DASH=null;

async function load(){
  if(!WID||!KEY) return;
  try{
    const r=await fetch(`/api/weddings/${WID}/dashboard`,{headers:{"x-admin-key":KEY}});
    if(!r.ok) throw 0;
    DASH=await r.json();
    render();
    $("stErr").classList.add("hidden");$("app").classList.remove("hidden");
  }catch(e){$("stErr").classList.remove("hidden");$("app").classList.add("hidden");}
}
function render(){
  const w=DASH.wedding,s=DASH.stats;
  const dt=new Date(w.wedding_date);
  const days=Math.max(0,Math.ceil((dt-Date.now())/864e5));
  $("hNames").textContent=`${w.partner1.split(" ")[0]} & ${w.partner2.split(" ")[0]}`;
  $("hSub").textContent=[w.venue,dt.toLocaleDateString("en-US",{month:"long",day:"numeric",year:"numeric"}),days?`${days} days to go`:""].filter(Boolean).join(" · ");
  $("stats").innerHTML=[[s.heads,"Attending"],[s.accepted,"Yes"],[s.pending,"Awaiting"],[s.declined,"Regrets"],["$"+(s.registry_raised_cents/100).toLocaleString(),"Registry"]]
    .map(([n,l])=>`<div class="stat"><div class="n">${n}</div><div class="l">${l}</div></div>`).join("");
  $("guestList").innerHTML=DASH.guests.length?DASH.guests.map(g=>`
    <div class="guest">
      <div><div class="nm">${esc(g.name)}</div>${g.email?`<div class="em">${esc(g.email)}</div>`:""}${g.rsvp_status==="Accepted"?`<div class="meal">${g.party_size} attending${g.meal?` · ${esc(g.meal)}`:""}</div>`:""}${g.allergies?`<div class="meal" style="color:#8E6836">⚠ ${esc(g.allergies)}</div>`:""}${g.transport?`<div class="meal">🚗 ${esc(g.transport)}</div>`:""}</div>
      <span class="pill ${g.rsvp_status==="Accepted"?"yes":g.rsvp_status==="Declined"?"no":"wait"}">${g.rsvp_status}</span>
      <div class="actions"><button class="btn btn-quiet xs" onclick="copyLink('${g.invite_url}','${esc(g.name)}')">Copy link</button></div>
    </div>`).join(""):`<div class="empty">No guests yet — add your first below.</div>`;
  const notes=DASH.guests.filter(g=>g.question||g.note);
  $("notesCard").classList.toggle("hidden",!notes.length);
  $("notesList").innerHTML=notes.map(g=>`<div class="note-row"><b>${esc(g.name)}</b> ${g.question?`<span>· asked: ${esc(g.question)}</span>`:""} ${g.note?`<span>· ${esc(g.note)}</span>`:""}</div>`).join("");
  const songs=(DASH.memories||[]).filter(m=>m.kind==="song");
  $("songsCard").classList.toggle("hidden",!songs.length);
  $("songsList").innerHTML=songs.map(m=>{
    const guest=DASH.guests.find(g=>g.id===m.guest_id);
    return `<div class="note-row"><b>${esc(m.text)}</b> ${guest?`<span>· requested by ${esc(guest.name)}</span>`:""}</div>`;
  }).join("");
  const meals={};
  DASH.guests.filter(g=>g.rsvp_status==="Accepted"&&g.meal).forEach(g=>{meals[g.meal]=(meals[g.meal]||0)+g.party_size});
  $("mealList").innerHTML=Object.keys(meals).length
    ?Object.entries(meals).map(([m,n])=>`<div class="note-row"><b>${n}</b> <span>· ${esc(m)}</span></div>`).join("")
    :`<div class="empty">Meal choices appear as replies come in.</div>`;

  const allergies = DASH.allergySummary || [];
  $("allergyCard").classList.toggle("hidden", !allergies.length);
  $("allergyList").innerHTML = allergies.map(a=>`<div class="note-row"><b>${a.count}</b> <span>· ${esc(a.text)}</span></div>`).join("");

  const events = DASH.events || [];
  $("eventCard").classList.toggle("hidden", events.length < 2);
  $("eventList").innerHTML = events.map(e=>`<div class="note-row"><b>${e.attending_count}</b> <span>· ${esc(e.title)} (${esc(e.day_label)}, ${esc(e.time_label)})</span></div>`).join("");
}
async function exportCsv(){
  try{
    const r = await fetch(`/api/weddings/${WID}/guests/export`, {headers:{"x-admin-key":KEY}});
    if (!r.ok) throw 0;
    const blob = await r.blob();
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url; a.download = "guests.csv";
    document.body.appendChild(a); a.click(); a.remove();
    URL.revokeObjectURL(url);
  }catch(e){ notice("Couldn't export right now — please try again."); }
}
async function addGuest(){
  const name=$("ng-name").value.trim(); if(!name) return notice("A name, at least.");
  try{
    const r=await fetch(`/api/weddings/${WID}/guests`,{method:"POST",headers:{"Content-Type":"application/json","x-admin-key":KEY},
      body:JSON.stringify({name,email:$("ng-email").value.trim()})});
    if(!r.ok) throw 0;
    $("ng-name").value="";$("ng-email").value="";
    await load();
    notice(`${name} added — their link is ready to copy.`);
  }catch(e){notice("That didn't save — please try again.")}
}
function copyLink(url,name){
  try{navigator.clipboard.writeText(url);notice(`${name}'s invitation link copied.`)}
  catch(e){prompt("Copy this link:",url)}
}
load();
</script>
</body>
</html>
